# Copy this file to `.env` (same directory) and fill in your real keys.
# `.env` is gitignored so your keys stay local.
#
# After creating .env, restart the server (uvicorn main:app --reload).
# Also clear any keys saved in the browser (app Settings panel -> blank both fields -> Save),
# otherwise the browser-sent key takes precedence over the .env value.

OPENAI_API_KEY=sk-proj-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
